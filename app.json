{
  "expo": {
    "name": "Moodly",
    "slug": "moodly",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "moodly",
    "splash": {
      "backgroundColor": "#FAFAFA",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.moodly.app"
    },
    "android": {
      "package": "com.moodly.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAFAFA"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
